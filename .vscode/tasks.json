{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "designer",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "call ${workspaceFolder}\\.venv\\Scripts\\activate.bat && pyside6-designer.exe"
      ],
      "problemMatcher": []
    },
    {
      "label": "build ui",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "call ${workspaceFolder}\\.venv\\Scripts\\activate.bat && python setup.py build_ui"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
